# Runtime environment for the production container.
# Copy to /opt/coderoad/.env on the VM and fill in real values. NEVER commit the real file.
# docker-compose.yml loads this via `env_file: .env`.
#
# IMPORTANT: put each value on its own line with NO inline `# comment` after it. Docker's
# env_file parser keeps everything after `=` literally (including a trailing `# ...`),
# unlike the dotenv loader used in local dev — an inline comment becomes part of the value.

# --- Database (Neon Postgres) ---
DATABASE_URL=

# --- Auth (better-auth) ---
BETTER_AUTH_SECRET=
# Must be the production base URL (e.g. https://coderoad.example.com).
BETTER_AUTH_URL=

# --- GitHub OAuth app + API ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PERSONAL_ACCESS_TOKEN=

# Public app URL = your reserved ngrok URL, e.g. https://your-reserved.ngrok-free.app
# NOTE: this is inlined at BUILD time via the Docker --build-arg (repo variable
# NEXT_PUBLIC_APP_BASE_URL), so the ngrok domain must be reserved BEFORE the image is built.
# It is ALSO read at runtime by server code (webhook registration), so set the same URL here.
# BETTER_AUTH_URL above must be this same ngrok URL.
NEXT_PUBLIC_APP_BASE_URL=

# --- AI providers ---
# 'gemini' (default) or 'anthropic'
AI_PROVIDER=gemini
GOOGLE_GENERATIVE_AI_API_KEY=
PINECONE_DB_API_KEY=
# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional Claude model override (default claude-sonnet-4-6)
ANTHROPIC_MODEL=

# --- Inngest (self-hosted dev server, see docker-compose.yml) ---
# Point the SDK at the self-hosted dev server container. The inngest SDK accepts a URL
# here (not just "1"/"true") and routes sent events to that dev server.
# Do NOT set INNGEST_SIGNING_KEY / INNGEST_EVENT_KEY in this mode — those are Inngest Cloud.
INNGEST_DEV=http://inngest:8288

# --- ngrok (public HTTPS tunnel to the app; see docker-compose.yml) ---
# Authtoken from your ngrok dashboard, and your reserved static domain (no https:// prefix).
NGROK_AUTHTOKEN=
NGROK_DOMAIN=your-reserved.ngrok-free.app

# --- Jira (optional ticket enrichment; per-user Settings config overrides these) ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
