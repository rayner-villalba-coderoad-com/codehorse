# Runtime environment for the production container.
# Copy to /opt/coderoad/.env on the VM and fill in real values. NEVER commit the real file.
# docker-compose.yml loads this via `env_file: .env`.
#
# IMPORTANT: put each value on its own line with NO inline `# comment` after it. Docker's
# env_file parser keeps everything after `=` literally (including a trailing `# ...`),
# unlike the dotenv loader used in local dev — an inline comment becomes part of the value.

# --- Database (Neon Postgres) ---
DATABASE_URL=

# --- Auth (better-auth) ---
BETTER_AUTH_SECRET=
# Must be the production base URL (e.g. https://coderoad.example.com).
BETTER_AUTH_URL=

# --- GitHub OAuth app + API ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PERSONAL_ACCESS_TOKEN=

# Public app URL. NOTE: this is inlined at BUILD time via the Docker --build-arg
# (repo variable NEXT_PUBLIC_APP_BASE_URL). It is ALSO read at runtime by server code
# (e.g. webhook registration), so set the same production URL here.
NEXT_PUBLIC_APP_BASE_URL=

# --- AI providers ---
# 'gemini' (default) or 'anthropic'
AI_PROVIDER=gemini
GOOGLE_GENERATIVE_AI_API_KEY=
PINECONE_DB_API_KEY=
# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional Claude model override (default claude-sonnet-4-6)
ANTHROPIC_MODEL=

# --- Inngest (PRODUCTION) ---
# In production the app must be registered with Inngest Cloud. Set these and DO NOT set
# INNGEST_DEV. After deploy, sync the app at https://<domain>/api/inngest in the Inngest
# dashboard so background review jobs actually run.
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# --- Jira (optional ticket enrichment; per-user Settings config overrides these) ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
